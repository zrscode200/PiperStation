{
  "$schema": "https://opencode.ai/config.json",
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000
  },
  "instructions": [
    "STATION.md",
    "PRODUCT.md",
    "ARCHITECTURE.md",
    "CONVENTIONS.md",
    "TESTING.md",
    "SECURITY.md",
    "automation-policy.md"
  ],
  "permission": {
    "edit": "ask",
    "bash": "ask",
    "openaiDeveloperDocs_*": "deny"
  },
  "mcp": {
    "openaiDeveloperDocs": {
      "type": "remote",
      "url": "https://developers.openai.com/mcp",
      "enabled": true
    }
  }
}
